# Managed by Ansible (debian_hardening role)
# Basic SSH hardening for Debian
{% set ssh_auth_mode = debian_hardening_ssh_auth_mode %}

# Root login policy
PermitRootLogin {{ debian_hardening_ssh_permit_root_login }}

# Authentication methods
PasswordAuthentication {{ (ssh_auth_mode in ['password_only', 'keys_and_password']) | ternary('yes','no') }}
KbdInteractiveAuthentication {{ (ssh_auth_mode in ['password_only', 'keys_and_password']) | ternary('yes','no') }}
PubkeyAuthentication {{ (ssh_auth_mode in ['keys_only', 'keys_and_password']) | ternary('yes','no') }}

# Limits and timeouts
MaxAuthTries {{ debian_hardening_ssh_max_auth_tries }}
LoginGraceTime {{ debian_hardening_ssh_login_grace_time }}

# Keep sessions alive but not forever
ClientAliveInterval {{ debian_hardening_ssh_client_alive_interval }}
ClientAliveCountMax {{ debian_hardening_ssh_client_alive_count_max }}

{% if debian_hardening_ssh_allow_groups | length > 0 %}
AllowGroups {{ debian_hardening_ssh_allow_groups | join(' ') }}
{% endif %}

# Force automation account to use keys only (no password fallback)
Match User {{ ansible_user }}
  PasswordAuthentication no
  KbdInteractiveAuthentication no
  PubkeyAuthentication yes
  AuthenticationMethods publickey
